{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "StudyMaterial": {
      "title": "Study Material",
      "description": "Stored study documents and AI-generated aids",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "rawContent": { "type": "string" },
        "summary": { "type": "string" },
        "topics": { "type": "array" },
        "mnemonics": { "type": "array" },
        "practiceQuestions": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "rawContent"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/materials/{materialId}": {
      "schema": "StudyMaterial",
      "description": "Study materials and their AI augmentations"
    }
  }
}
